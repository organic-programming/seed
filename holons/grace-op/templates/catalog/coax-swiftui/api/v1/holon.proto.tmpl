syntax = "proto3";
package holons.v1;

import "holons/v1/coax.proto";
import "holons/v1/manifest.proto";

option (holons.v1.manifest) = {
  identity: {
    schema: "holon/v1"
    uuid: "{{ .UUID }}"
    given_name: "{{ .GivenTitle }}"
    family_name: "{{ .FamilyTitle }}"
    motto: "SwiftUI app holon scaffold with COAX support."
    composer: "op new"
    status: "draft"
    born: "{{ .Date }}"
    version: "0.1.0"
  }
  description: "{{ .Slug }} scaffold generated from {{ .Template }}."
  lang: "swift"
  kind: "composite"
  transport: "stdio"
  platforms: ["macos"]
  contract: {
    proto: "api/v1/holon.proto"
    service: "holons.v1.CoaxService"
    rpcs: [
      "ListMembers",
      "MemberStatus",
      "ConnectMember",
      "DisconnectMember",
      "Tell",
      "TurnOffCoax"
    ]
  }
  build: {
    runner: "recipe"
    codegen: {
      languages: ["swift", "swift-grpc"]
    }
    templates: ["App/Info.plist", "project.yml"]
    defaults: {
      target: "macos"
      mode: "debug"
    }
    members: {
      id: "holon"
      path: "holon"
      type: "component"
    }
    members: {
      id: "app"
      path: "."
      type: "component"
    }
    targets: {
      key: "macos"
      value: {
        steps: {
          assert_file: {
            path: "App/{{ .PascalSlug }}App.swift"
          }
        }
        steps: {
          assert_file: {
            path: "project.yml"
          }
        }
        steps: {
          copy_all_holons: {
            to: ".op/build/{{ .PascalSlug }}App.app/Contents/Resources/Holons"
          }
        }
      }
    }
  }
  requires: {
    sdk_prebuilts: ["swift"]
  }
  artifacts: {
    primary: "App/{{ .PascalSlug }}App.swift"
  }
};
