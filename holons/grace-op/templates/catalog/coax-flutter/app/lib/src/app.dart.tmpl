class {{ .PascalSlug }}HomePage extends StatefulWidget {
  const {{ .PascalSlug }}HomePage({
    super.key,
    required this.appHolonManager,
    required this.coaxManager,
  });

  final AppHolonManager appHolonManager;
  final CoaxManager coaxManager;

  @override
  State<{{ .PascalSlug }}HomePage> createState() =>
      _{{ .PascalSlug }}HomePageState();
}

class _{{ .PascalSlug }}HomePageState extends State<{{ .PascalSlug }}HomePage> {
  late final AppLifecycleListener _appLifecycleListener;
  late final Listenable _listenable;
  Future<void>? _shutdownFuture;

  @override
  void initState() {
    super.initState();
    _appLifecycleListener = AppLifecycleListener(
      onExitRequested: _handleExitRequested,
    );
    _listenable = Listenable.merge(<Listenable>[
      widget.appHolonManager,
      widget.coaxManager,
    ]);
    WidgetsBinding.instance.addPostFrameCallback((_) async {
      if (!mounted || _shutdownFuture != null) {
        return;
      }
      await widget.appHolonManager.initialize();
      if (!mounted || _shutdownFuture != null) {
        return;
      }
      await widget.coaxManager.startIfEnabled();
    });
  }

  @override
  void dispose() {
    _appLifecycleListener.dispose();
    unawaited(_shutdownControllers());
    super.dispose();
  }

  Future<AppExitResponse> _handleExitRequested() async {
    await _shutdownControllers();
    return AppExitResponse.exit;
  }

  Future<void> _shutdownControllers() {
    final existing = _shutdownFuture;
    if (existing != null) {
      return existing;
    }
    final future = () async {
      await widget.coaxManager.shutdown();
      await widget.appHolonManager.shutdown();
    }();
    _shutdownFuture = future;
    return future;
  }

  Future<void> _showCoaxSettings(BuildContext context) {
    return showDialog<void>(
      context: context,
      builder: (_) => CoaxSettingsView(coaxManager: widget.coaxManager),
    );
  }

  @override
  Widget build(BuildContext context) {
    return AnimatedBuilder(
      animation: _listenable,
      builder: (context, _) {
        final organism = widget.appHolonManager;
        final coax = widget.coaxManager;
        final theme = Theme.of(context);
        final darkMode = theme.brightness == Brightness.dark;

        return Scaffold(
          child: DecoratedBox(
            decoration: BoxDecoration(
              gradient: LinearGradient(
                begin: Alignment.topCenter,
                end: Alignment.bottomCenter,
                colors: <Color>[
                  theme.colorScheme.background,
                  theme.colorScheme.accent.withValues(
                    alpha: darkMode ? 0.28 : 0.72,
                  ),
                  theme.colorScheme.muted.withValues(
                    alpha: darkMode ? 0.34 : 0.88,
                  ),
                ],
              ),
            ),
            child: SafeArea(
              child: Column(
                crossAxisAlignment: CrossAxisAlignment.stretch,
                children: [
                  Padding(
                    padding: const EdgeInsets.fromLTRB(32, 16, 32, 16),
                    child: CoaxControlsView(
                      coaxManager: coax,
                      onOpenSettings: () => _showCoaxSettings(context),
                    ),
                  ),
                  DecoratedBox(
                    decoration: BoxDecoration(
                      border: Border(
                        bottom: BorderSide(
                          color: theme.colorScheme.border.withValues(
                            alpha: 0.5,
                          ),
                        ),
                      ),
                    ),
                    child: const SizedBox(height: 0),
                  ),
                  Expanded(
                    child: Padding(
                      padding: const EdgeInsets.all(32),
                      child: Column(
                        crossAxisAlignment: CrossAxisAlignment.stretch,
                        children: [
                          _WorkspaceBar(controller: organism),
                          const SizedBox(height: 32),
                          Expanded(
                            child: Center(
                              child: ConstrainedBox(
                                constraints: const BoxConstraints(maxWidth: 760),
                                child: _PreviewCard(controller: organism),
                              ),
                            ),
                          ),
                        ],
                      ),
                    ),
                  ),
                ],
              ),
            ),
          ),
        );
      },
    );
  }
}

class _WorkspaceBar extends StatelessWidget {
  const _WorkspaceBar({required this.controller});

  final AppHolonManager controller;

  @override
  Widget build(BuildContext context) {
    final holonItems = controller.availableHolons
        .map(
          (identity) => SelectItemButton<_TemplateHolonIdentity>(
            value: identity,
            child: Text(identity.displayName),
          ),
        )
        .toList(growable: false);
    final transportItems = controller.capabilities.holonTransportNames
        .map(
          (value) => SelectItemButton<String>(
            value: value.rawValue,
            child: Text(value.title),
          ),
        )
        .toList(growable: false);

    return Row(
      crossAxisAlignment: CrossAxisAlignment.end,
      children: [
        Expanded(
          child: Column(
            crossAxisAlignment: CrossAxisAlignment.start,
            children: [
              Select<_TemplateHolonIdentity>(
                value: controller.selectedHolon,
                onChanged: (value) {
                  if (value != null) {
                    unawaited(controller.selectHolon(value.slug));
                  }
                },
                itemBuilder: (context, value) => Text(value.displayName),
                popup: (context) => SelectPopup(
                  items: SelectItemList(children: holonItems),
                ),
              ),
              if (controller.selectedHolon != null)
                Padding(
                  padding: const EdgeInsets.only(top: 6),
                  child: SelectableText(
                    controller.selectedHolon!.slug,
                  ).small().muted(),
                ),
            ],
          ),
        ),
        const SizedBox(width: 24),
        Column(
          crossAxisAlignment: CrossAxisAlignment.end,
          children: [
            Row(
              children: [
                const Text('mode:').small().semiBold(),
                SizedBox(
                  width: 180,
                  child: Select<String>(
                    value: controller.transport,
                    onChanged: (value) {
                    if (value != null) {
                      unawaited(controller.setTransport(value));
                    }
                  },
                    itemBuilder: (context, value) =>
                        Text(HolonTransportName.normalize(value).title),
                    popup: (context) => SelectPopup(
                      items: SelectItemList(children: transportItems),
                    ),
                  ),
                ),
              ],
            ).gap(8),
            Row(
              children: [
                Text(controller.statusTitle).small().semiBold(),
                SizedBox(
                  width: 10,
                  height: 10,
                  child: DecoratedBox(
                    decoration: BoxDecoration(
                      color: controller.statusColor,
                      shape: BoxShape.circle,
                    ),
                  ),
                ),
              ],
            ).gap(8),
          ],
        ),
      ],
    );
  }
}

