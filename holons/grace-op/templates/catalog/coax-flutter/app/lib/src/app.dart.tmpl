class AppHolonManager extends ChangeNotifier implements HolonManager {
  AppHolonManager({
    AppPlatformCapabilities? capabilities,
    String? initialTransport,
  }) : capabilities = capabilities ?? AppPlatformCapabilities.desktopCurrent(),
       transport = HolonTransportName.normalize(
         initialTransport ?? Platform.environment['OP_ASSEMBLY_TRANSPORT'],
       ).rawValue;

  final AppPlatformCapabilities capabilities;

  final List<_TemplateHolonIdentity> availableHolons = const <_TemplateHolonIdentity>[
    _TemplateHolonIdentity(
      slug: 'holon',
      displayName: '{{ .PascalSlug }} Holon',
      familyName: '{{ .FamilyTitle }}-Holon',
    ),
  ];

  bool _initialized = false;
  bool _disposed = false;

  bool isRunning = false;
  String greeting = 'Wire your business holon into this organism app.';
  String detail =
      'COAX is ready. The scaffolded member `holon` is a local demo bridge '
      'until you replace it with a real runtime.';
  String transport;
  _TemplateHolonIdentity? selectedHolon;

  String get statusTitle => isRunning ? 'Ready' : 'Offline';

  Color get statusColor => isRunning
      ? const Color(0xFF66B85E)
      : const Color(0xFFD96A6A);

  String get demoCommand =>
      'sample.v1.SampleHolon/SetGreeting {\"text\":\"Hello from COAX\"}';

  Future<void> initialize() async {
    if (_initialized) {
      return;
    }
    _initialized = true;
    selectedHolon = availableHolons.first;
    _safeNotify();
  }

  Future<void> shutdown() async {}

  Future<void> selectHolon(String slug) async {
    final holon = availableHolons.firstWhere(
      (value) => value.slug == slug,
      orElse: () => throw StateError("Holon '$slug' not found"),
    );
    selectedHolon = holon;
    detail = 'Selected ${holon.displayName}.';
    _safeNotify();
  }

  Future<void> setTransport(String value) async {
    final normalized = HolonTransportName.normalize(value);
    if (!capabilities.holonTransportNames.contains(normalized)) {
      throw StateError(
        'Transport "${normalized.rawValue}" is not available here.',
      );
    }
    transport = normalized.rawValue;
    detail = 'Transport set to ${normalized.title}.';
    _safeNotify();
  }

  Future<void> applyHumanGreeting() async {
    await _setGreetingText(
      'Hello from {{ .GivenTitle }} {{ .FamilyTitle }}.',
      detail:
          'The human button and COAX Tell both flow through the same state.',
    );
  }

  @override
  Future<List<MemberInfo>> listMembers() async {
    return availableHolons.map(_memberInfo).toList(growable: false);
  }

  @override
  Future<MemberInfo?> memberStatus(String slug) async {
    final match = availableHolons.where((item) => item.slug == slug).firstOrNull;
    if (match == null) {
      return null;
    }
    return _memberInfo(match);
  }

  @override
  Future<MemberInfo> connectMember(
    String slug, {
    String transport = '',
  }) async {
    if (transport.trim().isNotEmpty) {
      await setTransport(transport);
    }
    await selectHolon(slug);
    isRunning = true;
    detail =
        'Connected ${selectedHolon!.displayName} over ${HolonTransportName.normalize(transport).title}.';
    _safeNotify();
    return _memberInfo(
      selectedHolon!,
      overrideState: MemberState.MEMBER_STATE_CONNECTED,
    );
  }

  @override
  Future<void> disconnectMember(String slug) async {
    if (slug.trim().isNotEmpty && selectedHolon?.slug != slug) {
      return;
    }
    isRunning = false;
    detail = 'Disconnected member ${selectedHolon?.displayName ?? 'holon'}.';
    _safeNotify();
  }

  @override
  Future<Object?> tellMember({
    required String slug,
    required String method,
    Object? payloadJson,
  }) async {
    final canonicalMethod = _canonicalMethod(method);
    if (selectedHolon?.slug != slug) {
      await selectHolon(slug);
    }
    isRunning = true;

    final payloadMap = switch (payloadJson) {
      Map<Object?, Object?> value => value.map(
        (key, value) => MapEntry(key.toString(), value),
      ),
      null => const <String, Object?>{},
      _ => throw ArgumentError.value(
        payloadJson,
        'payloadJson',
        'Expected a JSON object',
      ),
    };

    switch (canonicalMethod) {
      case 'sample.v1.SampleHolon/Ping':
        detail =
            'Received Ping for ${selectedHolon!.displayName} over ${HolonTransportName.normalize(transport).title}.';
        _safeNotify();
        return <String, Object?>{
          'message': 'pong',
          'memberSlug': slug,
          'transport': transport,
        };

      case 'sample.v1.SampleHolon/SetGreeting':
        final text = payloadMap['text']?.toString().trim();
        final nextDetail = payloadMap['detail']?.toString().trim();
        await _setGreetingText(
          text == null || text.isEmpty ? greeting : text,
          detail: nextDetail?.isNotEmpty == true
              ? nextDetail!
              : 'Updated through COAX Tell.',
        );
        return <String, Object?>{
          'greeting': greeting,
          'detail': detail,
        };
    }

    throw ArgumentError.value(
      method,
      'method',
      'Unsupported demo method for the scaffolded member',
    );
  }

  Future<void> _setGreetingText(
    String value, {
    required String detail,
  }) async {
    greeting = value;
    this.detail = detail;
    isRunning = true;
    _safeNotify();
  }

  MemberInfo _memberInfo(
    _TemplateHolonIdentity holon, {
    MemberState? overrideState,
  }) {
    return MemberInfo(
      slug: holon.slug,
      identity: HolonManifest_Identity(
        familyName: holon.familyName,
        givenName: holon.displayName,
      ),
      state: overrideState ??
          (selectedHolon?.slug == holon.slug && isRunning
              ? MemberState.MEMBER_STATE_CONNECTED
              : MemberState.MEMBER_STATE_AVAILABLE),
      isOrganism: false,
    );
  }

  void _safeNotify() {
    if (!_disposed) {
      notifyListeners();
    }
  }

  static String _canonicalMethod(String method) {
    final trimmed = method.trim();
    if (trimmed.isEmpty) {
      throw ArgumentError.value(method, 'method', 'Method must not be empty');
    }
    return trimmed.startsWith('/') ? trimmed.substring(1) : trimmed;
  }

  @override
  void dispose() {
    _disposed = true;
    super.dispose();
  }
}

class _TemplateHolonIdentity {
  const _TemplateHolonIdentity({
    required this.slug,
    required this.displayName,
    required this.familyName,
  });

  final String slug;
  final String displayName;
  final String familyName;

  @override
  bool operator ==(Object other) =>
      other is _TemplateHolonIdentity && other.slug == slug;

  @override
  int get hashCode => slug.hashCode;
}

extension on Iterable<_TemplateHolonIdentity> {
  _TemplateHolonIdentity? get firstOrNull {
    final iterator = this.iterator;
    if (!iterator.moveNext()) {
      return null;
    }
    return iterator.current;
  }
}
