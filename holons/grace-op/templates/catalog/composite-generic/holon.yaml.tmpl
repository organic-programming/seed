schema: holon/v1
uuid: "{{.UUID}}"
given_name: "{{.GivenTitle}}"
family_name: "{{.FamilyTitle}}"
motto: "{{.DaemonKind}} + {{.HostUIKind}} composite."
composer: "grace-op scaffold"
status: "draft"
born: "{{.Date}}"
description: "Composite scaffold."
lang: "{{.DaemonKind}}+{{.HostUIKind}}"
kind: "composite"
build:
  members:
    - id: "daemon"
      path: "daemon"
      type: "holon"
    - id: "app"
      path: "app"
      type: "holon"
artifacts:
  primary: "app/app.txt"
