schema: holon/v1
uuid: "{{.UUID}}"
given_name: "{{.GivenTitle}}"
family_name: "{{.FamilyTitle}}"
motto: "{{.Service}} ready for {{.Slug}}."
composer: "grace-op scaffold"
status: "draft"
born: "{{.Date}}"
description: "Generated Go daemon."
lang: "go"
kind: "native"
build:
  runner: "go-module"
  main: "./cmd/{{.Slug}}"
requires:
  commands: ["go"]
  files: ["cmd/{{.Slug}}/main.go"]
artifacts:
  binary: "{{.Slug}}"
