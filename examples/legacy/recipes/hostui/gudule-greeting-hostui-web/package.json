{
  "name": "greeting-goweb",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "generate:proto": "node -e \"require('node:fs').mkdirSync('src/gen',{recursive:true})\" && protoc --es_out=src/gen --es_opt=target=ts proto/greeting.proto",
    "dev": "vite",
    "build": "npm run generate:proto && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.10.0",
    "js-web-holons": "file:../../../sdk/js-web-holons",
    "protobufjs": "^7.5.4"
  },
  "devDependencies": {
    "@bufbuild/protoc-gen-es": "^2.10.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.7"
  }
}
