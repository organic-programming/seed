# Organic Programming — Mac developer / self-hosted runner environment.
#
# Copy this file to ~/.op-mac.env on every Mac that needs the shared
# cache layout (core dev workstations and CI self-hosted runners alike):
#
#   cp scripts/op-mac.env.example ~/.op-mac.env
#
# CI loads this file directly via .github/actions/load-mac-runner-env at
# the start of every Mac job. You do NOT need to source it from your
# shell rc for CI to pick it up — copying the file is enough.
#
# If you also want these variables in your interactive sessions, you
# can source it manually from your shell rc, but that is independent
# from CI.

export ADER_CI_CACHE_BASE="$HOME/.ader-ci-cache"
export GRACE_OP_SHARED_CACHE_DIR="$HOME/.ader-ci-cache/grace-op-shared"
export GOMODCACHE="$HOME/.ader-ci-cache/go-mod"
export GOCACHE="$HOME/.ader-ci-cache/go-build"
export BUNDLE_PATH="$HOME/.ader-ci-cache/bundle"
export PUB_CACHE="$HOME/.ader-ci-cache/dart-pub"
export npm_config_cache="$HOME/.ader-ci-cache/npm"
export GRADLE_USER_HOME="$HOME/.ader-ci-cache/gradle"
export NUGET_PACKAGES="$HOME/.ader-ci-cache/nuget"
export DOTNET_CLI_HOME="$HOME/.ader-ci-cache/dotnet-home"
