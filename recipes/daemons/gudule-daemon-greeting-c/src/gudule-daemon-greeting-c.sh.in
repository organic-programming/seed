#!/usr/bin/env bash
set -euo pipefail

BACKEND_BIN="@CMAKE_RUNTIME_OUTPUT_DIRECTORY@/@BACKEND_NAME@"
BRIDGE_BIN="@SDK_ROOT@/bin/grpc-bridge"
PROTO_DIR="@GREETING_PROTO_DIR@"
HOLON_YAML="@HOLON_YAML@"

if [[ "${1:-}" == "version" ]]; then
  exec "${BACKEND_BIN}" "$@"
fi

if [[ "${1:-}" == "serve" ]]; then
  shift
  exec "${BRIDGE_BIN}" --backend "${BACKEND_BIN}" --proto-dir "${PROTO_DIR}" --holon-yaml "${HOLON_YAML}" "$@"
fi

exec "${BACKEND_BIN}" "$@"
